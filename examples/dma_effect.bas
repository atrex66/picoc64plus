

10 S =180
20 K=3.1415/(S/2)
REM SPRITE PARAMETERS
REM SPRITE WIDTH = 52
30 POKE $A000,52
REM SPRITE HEIGHT = 58
40 POKE $A001,58
REM ENABLE SPRITE0
50 POKE $A002,1
REM SPRITE0 MEMORY ADDRESS = $9000
60 WOKE $A008,$9000
REM SET TRANSPARENCY COLOR = 0
70 POKE $A007,0
REM CLEAR SPRITE MEMORY
80 POKE $D800,0
90 DMAFILL $D800,$9000,52*58

130 POKE $DC00, 208
140 DMAFILL $DC00,$0400,1000
150 FOR I=1 TO 52*58-1
155 C=3.141592+0.02*COS(I*2/I)
160 POKE$9000+I,24+(8*SIN(I*C/26))
170 NEXT I



1 W=10
2 H=20
3 SA=$8000
4 SB=$9000
5 S0=$A000
6 S1=S0+10
REM SPRITE 1
10 POKE S0+0,W
12 POKE S0+1,H
14 POKE S0+2,1
16 WOKE S0+3,0
18 WOKE S0+5,0
20 POKE S0+7,0
22 WOKE S0+8,SA
REM SPRITE 2
24 POKE S1+0,W
26 POKE S1+1,H
28 POKE S1+2,0
30 WOKE S1+3,0
32 WOKE S1+5,0
34 POKE S1+7,0
36 WOKE S1+8,SB
40 POKE $DC00,0
42 DMACPY $DC00,SA,W*H
44 DMACPY $DC00,SB,W*H
46 FOR I=0 TO (W*H)-1
48 X=RND(1)*100
50 IF X>70 THEN POKE $8000+I,1
52 NEXT
60 FOR X=0 TO W
65 FOR Y=0 TO H
70 A = 0
80 A = A + PEEK(SA+X+Y*W)
85 IF X<1 THEN 95
90 A = A + PEEK(SA+X-1+Y*W)
95 IF X>W-1 THEN 105
100 A = A + PEEK(SA+X+1+Y*W)
105 IF Y<1 THEN 115
110 A = A + PEEK(SA+X+(Y-1)*W)
115 IF Y>H-1 THEN 125
120 A = A + PEEK(SA+X+(Y+1)*W)
125 IF X<1 OR Y<1 THEN 145
130 A = A + PEEK(SA+X-1+(Y-1)*W)
140 A = A + PEEK(SA+X+1+(Y-1)*W)
145 IF X>W-1 OR Y>H-1 THEN 170
150 A = A + PEEK(SA+X-1+(Y+1)*W)
160 A = A + PEEK(SA+X+1+(Y+1)*W)
170 IF A=3 THEN POKE SB+X+Y*W,1
180 IF A=2 AND PEEK(SA+X+Y*W)=1 THEN POKE SB+X+Y*W,1
190 NEXT
200 NEXT
210 DMACPY $DC00,SB,W*H
220 GETA$:IFA$=""THEN60

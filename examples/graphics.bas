REM THIS PROGRAM IS USES SPRITE0 FOR GRAPHICS
REM DEFINES THE SPRITE PARAMETERS AND DRAW A CIRCLE

10 S =180
20 K=3.1415/(S/2)
REM SPRITE PARAMETERS
REM SPRITE WIDTH = 52
30 POKE $A000,52
REM SPRITE HEIGHT = 58
40 POKE $A001,58
REM ENABLE SPRITE0
50 POKE $A002,1
REM SPRITE0 MEMORY ADDRESS = $9000
60 WOKE $A008,$9000
REM SET TRANSPARENCY COLOR = 0
70 POKE $A007,0
REM CLEAR SPRITE MEMORY
80 POKE $D800,0
90 DMAFILL $D800,$9000,52*58
REM DRAW CIRCLE
100 FOR I=0 TO S
110 X=INT(26+(25*SIN(I*K)))
120 Y=INT(29+(28*COS(I*K)))
REM IT IS IMPORTANT TO CONVERT X AND Y
REM TO INTEGER VALUES OTHERWISE THE POKE WILL FAIL
130 POKE $9000+(Y*52)+X,1
140 NEXT I
REM WAIT FOR KEY PRESS
150 GETA$:IFA$=""THEN150
160 POKE $A002,0

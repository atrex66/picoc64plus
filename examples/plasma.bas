5 W=52 :REM SPRITE WIDTH
6 H=58 :REM SPRITE HEIGHT
7 AB = $B000 :REM SPRITE BUFFER ADDRESS
10 POKE $A000,W
20 POKE $A001,H
30 POKE $A002,1
40 WOKE $A003,0
50 WOKE $A005,0
60 POKE $A007,255 
70 WOKE $A008,AB
80 POKE $02,255
90 DMAFILL $02,AB,W*H
95 CLS
100 FOR Y=1 TO H
105 FOR X=1 TO W
110 A=SIN(Y/5)*COS(X/5)+LOG(X+Y)
115 POKE AB+(X-1)+(Y-1)*W,ABS(A*8)+24
120 NEXT X
130 NEXT Y
150 GETA$:IF A$=""THEN150
160 POKE $A002,0
170 DMAFILL $02,AB,W*H

5 CLS
8 G=0
10 BORDER 0
20 BACKGROUND 0
30 POKE $9000,19
40 DMAFILL $9000,$D800,1000
50 FOR I=0 TO 999
60 POKE $0400+I,RND(1)*96
70 NEXT
72 GOSUB 500
78 FOR Q=24 TO 1 STEP -1
79 S=55296+(40*Q):E =55296+(40*(Q-1))
80 DMACPY E , S , 40
82 NEXT
110 FOR I=$D800 TO $D800 + 40
120 J = PEEK(I)
130 IF J>19 THEN POKE I,J-1
140 NEXT
145 G=G+1
